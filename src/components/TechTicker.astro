---
const techs = [
  'TYPESCRIPT', 'PYTHON', 'RUST', 'GO', 'POWERSHELL', 'GDSCRIPT',
  'BUN', 'NODE.JS', 'REACT', 'ASTRO', 'TAURI', 'DJANGO',
  'TAILWIND CSS', 'POSTGRESQL', 'SUPABASE', 'REDIS', 'DOCKER',
  'CLOUDFLARE', 'GITHUB ACTIONS', 'LANGCHAIN', 'OPENAI', 'ANTHROPIC',
  'GEMINI', 'MULTI-AGENT LLM', 'MCP SERVERS', 'COPILOT EXTENSIONS',
  'AGENT ORCHESTRATION', 'COMPILER DESIGN',
]
const allTechs = [...techs, ...techs]
---

<div class="relative w-full overflow-hidden py-10 bg-surface-lowest" style="border-top: 1px solid rgba(59, 73, 75, 0.08); border-bottom: 1px solid rgba(59, 73, 75, 0.08);">
  <!-- Fade edges -->
  <div class="absolute left-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to right, #0e0e0e, transparent);"></div>
  <div class="absolute right-0 top-0 bottom-0 w-24 z-10 pointer-events-none" style="background: linear-gradient(to left, #0e0e0e, transparent);"></div>

  <div class="ticker-track">
    {allTechs.map((tech) => (
      <div class="flex items-center gap-6 px-6 shrink-0">
        <span class="font-label text-[11px] text-on-surface-variant/80 uppercase tracking-[0.2em] whitespace-nowrap hover:text-cyan transition-colors duration-300">{tech}</span>
        <span class="text-cyan/20 text-[6px]">&diams;</span>
      </div>
    ))}
  </div>
</div>
