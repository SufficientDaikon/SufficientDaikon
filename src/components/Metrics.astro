---
const metrics = [
  {
    label: 'REPOSITORIES',
    value: '62',
    numericValue: 62,
    suffix: '',
    icon: 'folder_copy',
    description: '51 public, 11 private. TypeScript, Python, Rust, Go, GDScript, and more.',
  },
  {
    label: 'AI_AGENTS_BUILT',
    value: '17',
    numericValue: 17,
    suffix: '',
    icon: 'smart_toy',
    description: 'Copilot Chat agents, CLI agents, MCP servers, and autonomous debuggers.',
  },
  {
    label: 'ARCHON_SKILLS',
    value: '83',
    numericValue: 83,
    suffix: '',
    icon: 'extension',
    description: 'Cross-platform agent skills deployed across 5 AI editor environments.',
  },
  {
    label: 'LANGUAGES',
    value: '11',
    numericValue: 11,
    suffix: '',
    icon: 'translate',
    description: 'TypeScript, Python, Rust, Go, PowerShell, GDScript, Java, PHP, Shell, C#, SQL.',
  },
]

const skills = [
  { label: 'AI AGENT ARCHITECTURE', pct: 96 },
  { label: 'FULL-STACK ENGINEERING', pct: 93 },
  { label: 'LLM ORCHESTRATION', pct: 91 },
  { label: 'DEVOPS / SYSADMIN', pct: 88 },
  { label: 'SYSTEMS PROGRAMMING', pct: 85 },
  { label: 'COMPILER / LANGUAGE DESIGN', pct: 78 },
]
---

<section id="metrics" class="relative py-28 lg:py-36 forensic-grid overflow-hidden">
  <!-- Neural network canvas behind metrics -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <canvas id="neural-canvas"></canvas>
  </div>

  <!-- Topographic contour layer -->
  <div class="absolute inset-0 topo-bg pointer-events-none" aria-hidden="true"></div>

  <div class="relative max-w-7xl mx-auto px-6 lg:px-16 xl:px-24 z-10">
    <div class="flex items-center gap-4 mb-3">
      <span class="section-label block reveal">PERFORMANCE_LOGS</span>
      <!-- Signal bars next to title -->
      <div class="signal-bars reveal">
        <div class="signal-bar" style="height: 4px;"></div>
        <div class="signal-bar" style="height: 7px;"></div>
        <div class="signal-bar" style="height: 10px;"></div>
        <div class="signal-bar" style="height: 14px;"></div>
        <div class="signal-bar" style="height: 16px;"></div>
      </div>
    </div>
    <h2 class="font-headline text-3xl lg:text-5xl font-extrabold text-on-surface tracking-tight mb-16 reveal glitch-hover heading-reveal" data-text="The Ledger">
      The Ledger
    </h2>

    <!-- Metric Cards Grid with holo effect -->
    <div class="grid grid-cols-1 sm:grid-cols-2 xl:grid-cols-4 gap-[1px]" style="background: rgba(59, 73, 75, 0.15);">
      {metrics.map((metric, i) => (
        <div
          class="metric-card holo-card group p-7 lg:p-10 bg-surface-lowest hover:bg-surface-low cursor-default reveal-scale tilt-card"
          data-counter-target={metric.numericValue}
          data-counter-suffix={metric.suffix}
          style={`transition-delay: ${i * 100}ms;`}
        >
          <div class="tilt-card-inner relative z-[2]">
            <div class="flex items-center justify-between mb-6">
              <span class="font-label text-[9px] text-on-surface-variant uppercase tracking-[0.25em]">
                {metric.label}
              </span>
              <span class="material-symbols-outlined text-[18px] text-outline-variant/40 group-hover:text-cyan/60 transition-colors duration-300">
                {metric.icon}
              </span>
            </div>

            <span
              class="counter-value font-headline text-4xl lg:text-5xl xl:text-[3.5rem] font-bold text-on-surface group-hover:text-cyan transition-colors duration-300 block mb-4"
              data-final={metric.value}
            >
              0
            </span>

            <p class="font-body text-sm text-on-surface-dim leading-relaxed">
              {metric.description}
            </p>
          </div>
        </div>
      ))}
    </div>

    <!-- Radar Sweep Section -->
    <div class="mt-20 grid lg:grid-cols-[1fr_300px] gap-12 items-start">
      <!-- Skill Bars -->
      <div class="skill-bars-container">
        <span class="section-label block mb-8 reveal">CAPABILITY_MATRIX</span>
        <div class="space-y-5 reveal">
          {skills.map((skill) => (
            <div>
              <div class="flex justify-between mb-2">
                <span class="font-label text-[10px] text-on-surface-variant uppercase tracking-[0.2em]">{skill.label}</span>
                <span class="font-label text-[10px] text-cyan-dim">{skill.pct}%</span>
              </div>
              <div class="skill-bar">
                <div class="skill-bar-fill" style={`--bar-width: ${skill.pct}%;`}></div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Radar Unit — Skill Domain Visualization -->
      <div class="relative hidden lg:block reveal-scale" aria-hidden="true">
        <div class="relative w-full aspect-square" style="max-width: 280px;">
          <!-- Radar rings — increased visibility -->
          <div class="absolute inset-0 border border-cyan/[0.12] rounded-full"></div>
          <div class="absolute inset-[20%] border border-cyan/[0.15] rounded-full"></div>
          <div class="absolute inset-[40%] border border-cyan/[0.18] rounded-full"></div>
          <!-- Crosshair lines — bolder -->
          <div class="absolute top-0 bottom-0 left-1/2 w-[1px] bg-cyan/[0.12]"></div>
          <div class="absolute left-0 right-0 top-1/2 h-[1px] bg-cyan/[0.12]"></div>
          <!-- Diagonal crosshairs for extra detail -->
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-full h-[1px] bg-cyan/[0.06]" style="transform: rotate(45deg);"></div>
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <div class="w-full h-[1px] bg-cyan/[0.06]" style="transform: rotate(-45deg);"></div>
          </div>
          <!-- Sweep arm -->
          <div class="radar-sweep"></div>
          <!-- Center dot — larger with glow rings -->
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-3 h-3 bg-cyan" style="box-shadow: 0 0 16px rgba(0, 240, 255, 0.9), 0 0 40px rgba(0, 240, 255, 0.3);"></div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-6 h-6 border border-cyan/30 rounded-full" style="animation: pulse-glow 2s ease-in-out infinite;"></div>
          <!-- Skill domain blips with labels -->
          <div class="absolute" style="top: 22%; left: 68%;">
            <div class="w-2.5 h-2.5 bg-cyan/70" style="box-shadow: 0 0 12px rgba(0, 240, 255, 0.6); animation: pulse-slow 2s ease-in-out infinite;"></div>
            <span class="absolute left-4 top-0 font-label text-[7px] text-cyan/50 uppercase tracking-[0.15em] whitespace-nowrap">AI/ML</span>
          </div>
          <div class="absolute" style="top: 60%; left: 18%;">
            <div class="w-2 h-2 bg-cyan/50" style="box-shadow: 0 0 10px rgba(0, 240, 255, 0.4); animation: pulse-slow 3s ease-in-out infinite;"></div>
            <span class="absolute left-4 top-0 font-label text-[7px] text-cyan/40 uppercase tracking-[0.15em] whitespace-nowrap">DEVOPS</span>
          </div>
          <div class="absolute" style="top: 15%; left: 32%;">
            <div class="w-1.5 h-1.5 bg-cyan/40" style="box-shadow: 0 0 8px rgba(0, 240, 255, 0.3); animation: pulse-slow 2.5s ease-in-out infinite;"></div>
            <span class="absolute left-4 top-0 font-label text-[7px] text-cyan/40 uppercase tracking-[0.15em] whitespace-nowrap">SYSTEMS</span>
          </div>
          <div class="absolute" style="top: 42%; left: 75%;">
            <div class="w-2 h-2 bg-cyan/50" style="box-shadow: 0 0 10px rgba(0, 240, 255, 0.4); animation: pulse-slow 1.8s ease-in-out infinite;"></div>
            <span class="absolute left-4 top-0 font-label text-[7px] text-cyan/50 uppercase tracking-[0.15em] whitespace-nowrap">FULL-STACK</span>
          </div>
          <div class="absolute" style="top: 78%; left: 58%;">
            <div class="w-1.5 h-1.5 bg-cyan/35" style="box-shadow: 0 0 6px rgba(0, 240, 255, 0.25); animation: pulse-slow 2.8s ease-in-out infinite;"></div>
            <span class="absolute left-4 top-0 font-label text-[7px] text-cyan/35 uppercase tracking-[0.15em] whitespace-nowrap">COMPILERS</span>
          </div>
          <!-- Axis labels -->
          <span class="absolute top-0 left-1/2 -translate-x-1/2 -translate-y-5 font-label text-[7px] text-cyan/40 tracking-[0.2em]">DEPTH</span>
          <span class="absolute bottom-0 left-1/2 -translate-x-1/2 translate-y-4 font-label text-[7px] text-cyan/40 tracking-[0.2em]">BREADTH</span>
          <span class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-8 font-label text-[7px] text-cyan/40 tracking-[0.2em]">THEORY</span>
          <span class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-5 font-label text-[7px] text-cyan/40 tracking-[0.2em]">APPLIED</span>
        </div>
        <span class="block text-center font-label text-[9px] text-outline/50 uppercase tracking-[0.3em] mt-6">DOMAIN_MAP // ACTIVE SWEEP</span>
      </div>
    </div>
  </div>
</section>

<script>
  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;

        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.counterTarget || '0');
        const suffix = el.dataset.counterSuffix || '';
        const valueEl = el.querySelector('.counter-value') as HTMLElement;
        if (!valueEl) return;

        const duration = 1500;
        const startTime = performance.now();

        function animate(currentTime: number) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const eased = 1 - Math.pow(1 - progress, 3);
          const current = Math.floor(eased * target);

          if (target > 999) {
            valueEl.textContent = current.toLocaleString() + suffix;
          } else {
            valueEl.textContent = current.toString() + suffix;
          }

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            valueEl.textContent = valueEl.dataset.final || '';
          }
        }

        requestAnimationFrame(animate);
        counterObserver.unobserve(el);
      });
    },
    { threshold: 0.3 }
  );

  document.querySelectorAll('.metric-card').forEach((card) => {
    counterObserver.observe(card);
  });
</script>
