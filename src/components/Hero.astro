<script>
  // Text scramble effect
  const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789!@#$%^&*()_+-=[]{}|;:,.<>?';

  function scrambleText(element: HTMLElement, finalText: string, duration: number = 1200) {
    const length = finalText.length;
    let frame = 0;
    const totalFrames = duration / 30;

    const interval = setInterval(() => {
      let output = '';
      for (let i = 0; i < length; i++) {
        if (finalText[i] === ' ') {
          output += ' ';
        } else if (frame / totalFrames > i / length) {
          output += finalText[i];
        } else {
          output += chars[Math.floor(Math.random() * chars.length)];
        }
      }
      element.textContent = output;
      frame++;
      if (frame > totalFrames) clearInterval(interval);
    }, 30);
  }

  // Wait for boot sequence to finish
  setTimeout(() => {
    const line1 = document.getElementById('scramble-line-1');
    const line2 = document.getElementById('scramble-line-2');
    if (line1) scrambleText(line1, 'I build autonomous', 1200);
    setTimeout(() => {
      if (line2) scrambleText(line2, 'systems that build', 1000);
    }, 500);
  }, 3000);

  // Terminal typing streamer
  const terminalLines = [
    'PORTFOLIO_INIT // AHMED TAHA',
    'LOCATION: CAIRO, EGYPT',
    'LOADING AGENT_CORES: 17',
    'SKILLS_REGISTRY: 83 ACTIVE',
    'REPOSITORIES: 62 // 51 PUBLIC',
    '---',
    'ARCHON ............. DEPLOYED',
    'AETHER ............. PAUSED',
    'AXON_COMPILER ...... ACTIVE',
    'HUGBROWSE .......... SHIPPED',
    'FEINIX_OS .......... RESEARCH',
    'DAEDALUS ........... ACTIVE',
    'GODOT_KIT .......... SHIPPED',
    '---',
    'COPILOT_AGENTS: 17 DEPLOYED',
    'MCP_SERVERS: 5 ONLINE',
    'PIPELINES: ALL_NOMINAL',
    'ALL_SYSTEMS: OPERATIONAL',
    'AWAITING_INPUT_\u25AE',
  ];

  const termContainer = document.getElementById('terminal-streamer');
  if (termContainer) {
    let lineIdx = 0;
    let charIdx = 0;
    let currentLine = document.createElement('div');
    termContainer.appendChild(currentLine);

    function typeChar() {
      if (lineIdx >= terminalLines.length) {
        lineIdx = 0;
        termContainer!.innerHTML = '';
        currentLine = document.createElement('div');
        termContainer!.appendChild(currentLine);
      }
      if (charIdx < terminalLines[lineIdx].length) {
        currentLine.textContent += terminalLines[lineIdx][charIdx];
        charIdx++;
        setTimeout(typeChar, 25 + Math.random() * 35);
      } else {
        lineIdx++;
        charIdx = 0;
        currentLine = document.createElement('div');
        termContainer!.appendChild(currentLine);
        while (termContainer!.children.length > 10) {
          termContainer!.removeChild(termContainer!.firstChild!);
        }
        setTimeout(typeChar, 300 + Math.random() * 400);
      }
    }
    setTimeout(typeChar, 3500);
  }

  // Coordinate readout
  const heroSection = document.getElementById('hero');
  const coordReadout = document.getElementById('coord-readout');
  if (heroSection && coordReadout) {
    heroSection.addEventListener('mousemove', (e) => {
      const rect = heroSection.getBoundingClientRect();
      const x = Math.floor(e.clientX - rect.left);
      const y = Math.floor(e.clientY - rect.top);
      coordReadout.textContent = `X: ${String(x).padStart(4, '0')} // Y: ${String(y).padStart(4, '0')}`;
    });
  }

  // Live Cairo Clock
  function updateClock() {
    const clockEl = document.getElementById('monolith-clock');
    const dateEl = document.getElementById('monolith-date');
    if (!clockEl || !dateEl) return;
    const now = new Date();
    const timeStr = now.toLocaleTimeString('en-US', {
      timeZone: 'Africa/Cairo',
      hour12: false,
      hour: '2-digit',
      minute: '2-digit',
      second: '2-digit'
    });
    const dateStr = now.toLocaleDateString('en-US', {
      timeZone: 'Africa/Cairo',
      year: 'numeric',
      month: 'short',
      day: '2-digit'
    }).toUpperCase().replace(',', '');
    clockEl.textContent = timeStr;
    dateEl.textContent = dateStr;
  }
  updateClock();
  setInterval(updateClock, 1000);
</script>
