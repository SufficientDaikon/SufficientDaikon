            <span class="bw-cc-label">GITHUB</span>
            <a href="https://github.com/SufficientDaikon" target="_blank" class="bw-cc-val">/SufficientDaikon</a>
          </div>
          <div class="bw-cc-row">
            <span class="bw-cc-label">LINKEDIN</span>
            <a href="https://linkedin.com/in/ahmed-taha225" target="_blank" class="bw-cc-val">/ahmed-taha225</a>
          </div>
          <div class="bw-cc-row">
            <span class="bw-cc-label">LOCATION</span>
