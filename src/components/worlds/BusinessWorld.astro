}
@media (min-width: 1024px) { .bw-hero { padding: 4rem 5rem; } }

.bw-hero-bg { position: absolute; inset: 0; pointer-events: none; overflow: hidden; }
.bw-hero-img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
