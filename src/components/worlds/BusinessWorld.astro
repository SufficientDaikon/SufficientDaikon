<script>
  // Business World entrance animations via IntersectionObserver
  const bwRoot = document.getElementById('world-business-overlay');
  if (bwRoot) {
    const animTargets = bwRoot.querySelectorAll<HTMLElement>(
      '.bw-big-metric, .bw-chart, .bw-hero-right > *, .bw-bar-row, ' +
      '.bw-track-card, .bw-method-step, .bw-engagement-block, ' +
      '.bw-contact-block, .bw-hero-left > *'
    );

    animTargets.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.5s cubic-bezier(0.16,1,0.3,1), transform 0.5s cubic-bezier(0.16,1,0.3,1)';
    });

    // Also animate the bar fills from width 0
    const barFills = bwRoot.querySelectorAll<HTMLElement>('.bw-bar-fill');
    barFills.forEach(bar => {
      const targetWidth = bar.style.width;
      bar.dataset.targetWidth = targetWidth;
      bar.style.width = '0%';
      bar.style.transition = 'width 0.8s cubic-bezier(0.16,1,0.3,1)';
    });

    const bwObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          const siblings = el.parentElement?.children;
          const idx = siblings ? Array.from(siblings).indexOf(el) : 0;
          setTimeout(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
            // If this is a bar fill, animate to target width
            if (el.classList.contains('bw-bar-fill') && el.dataset.targetWidth) {
              el.style.width = el.dataset.targetWidth;
            }
          }, idx * 80);
          bwObserver.unobserve(el);
        }
      });
    }, { root: bwRoot, threshold: 0.1, rootMargin: '0px 0px -8% 0px' });

    animTargets.forEach(el => bwObserver.observe(el));
    barFills.forEach(bar => bwObserver.observe(bar));
  }
</script>