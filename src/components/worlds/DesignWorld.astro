    </div>

    <!-- Scroll hint -->
    <div class="dw-scroll-hint">
      <span>SCROLL TO EXPLORE</span>
      <div class="dw-scroll-line"></div>
    </div>
  </section>

  <!-- WORK SECTION -->
  <section class="dw-section" id="dw-work">
    <div class="dw-section-inner">
      <div class="dw-section-header">
        <span class="dw-section-num">01 //</span>
        <h2 class="dw-section-title">SELECTED WORK</h2>
      </div>

      <div class="dw-work-grid">
        <!-- The Artifact (this portfolio) -->
        <div class="dw-work-item dw-work-featured">
          <div class="dw-work-img dw-work-img-artifact">
            <div class="dw-work-img-content">
              <span class="dw-work-img-label">FORENSIC MONOLITH</span>
              <div class="dw-work-img-grid"></div>
            </div>
          </div>
