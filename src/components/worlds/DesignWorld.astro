  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.dw-title-line.dw-line-3 {
  color: rgba(248,244,255,0.65);
  font-size: 0.75em;
  font-weight: 400;
  letter-spacing: 0.02em;
}

.dw-hero-body {
  font-family: 'Inter', sans-serif;
  font-size: clamp(14px, 1.5vw, 16px);
  color: rgba(255,255,255,0.5);
  line-height: 1.75;
  margin: 0 0 2rem;
  max-width: 480px;
}
.dw-hero-body strong { color: rgba(192,132,252,0.9); font-weight: 500; }

.dw-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-bottom: 1.5rem;
}
.dw-tag {
  font-family: 'Space Grotesk', monospace;
  font-size: 8px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: rgba(192,132,252,0.6);
  border: 1px solid rgba(192,132,252,0.2);
  padding: 4px 10px;
}

/* Stats row */
.dw-stats-row {
  display: flex;
  align-items: center;
  gap: 0;
  margin-bottom: 2rem;
  padding: 1rem 0;
  border-top: 1px solid rgba(192,132,252,0.15);
  border-bottom: 1px solid rgba(192,132,252,0.15);
}
.dw-stat {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  padding: 0 1.5rem 0 0;
}
.dw-stat:first-child { padding-left: 0; }
.dw-stat-val {
  font-family: 'Manrope', sans-serif;
  font-size: clamp(1.4rem, 2.5vw, 2.2rem);
  font-weight: 800;
  color: #C084FC;
  line-height: 1;
  letter-spacing: -0.02em;
}
.dw-stat-label {
  font-family: 'Space Grotesk', monospace;
  font-size: 7px;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: rgba(192,132,252,0.45);
  margin-top: 3px;
}
.dw-stat-sep {
  width: 1px;
  height: 32px;
  background: rgba(192,132,252,0.2);
  margin: 0 1.5rem 0 0;
  flex-shrink: 0;
}

.dw-ctas {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.dw-cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 24px;
  background: linear-gradient(135deg, #7C3AED, #EC4899);
  font-family: 'Space Grotesk', monospace;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #fff;
  text-decoration: none;
  transition: opacity 0.2s ease, transform 0.2s ease;
