<script>
  // Design World entrance animations via IntersectionObserver
  // (separate from GSAP ScrollTrigger since this world has its own scroll container)
  const dwRoot = document.getElementById('world-design-overlay');
  if (dwRoot) {
    const animTargets = dwRoot.querySelectorAll<HTMLElement>(
      '.dw-hero-title, .dw-hero-body, .dw-tags, .dw-ctas, .dw-card, ' +
      '.dw-work-item, .dw-work-featured, .dw-process-step, .dw-principles-grid > div, ' +
      '.dw-contact-block, .dw-hero-right'
    );

    // Set initial hidden state
    animTargets.forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'opacity 0.6s cubic-bezier(0.16,1,0.3,1), transform 0.6s cubic-bezier(0.16,1,0.3,1)';
    });

    const dwObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry, i) => {
        if (entry.isIntersecting) {
          const el = entry.target as HTMLElement;
          // Stagger based on element index within its parent
          const siblings = el.parentElement?.children;
          const idx = siblings ? Array.from(siblings).indexOf(el) : 0;
          setTimeout(() => {
            el.style.opacity = '1';
            el.style.transform = 'translateY(0)';
          }, idx * 60);
          dwObserver.unobserve(el);
        }
      });
    }, { root: dwRoot, threshold: 0.1, rootMargin: '0px 0px -8% 0px' });

    animTargets.forEach(el => dwObserver.observe(el));
  }
</script>