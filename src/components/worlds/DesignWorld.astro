              <div class="dw-mini-bar" style="width:85%;background:linear-gradient(90deg,#C084FC,#EC4899)"></div>
              <div class="dw-mini-bar" style="width:70%;background:linear-gradient(90deg,#7C3AED,#C084FC)"></div>
              <div class="dw-mini-bar" style="width:55%;background:#FBBF24"></div>
